# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Prefer a restricted key with Checkout Session permissions.
STRIPE_RESTRICTED_KEY=rk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREGNANCY=price_...
STRIPE_PRICE_POSTPARTUM=price_...
STRIPE_PRICE_MOMS_ANY_PHASE=price_...

# Supabase server access
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=...

# Resend
RESEND_API_KEY=re_...
FROM_EMAIL=hello@example.com
CONTACT_TO_EMAIL=erin@example.com
# Optional; falls back to CONTACT_TO_EMAIL.
PROGRAM_PURCHASE_TO_EMAIL=erin@example.com
